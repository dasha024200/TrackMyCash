@model TrackMyCash.ViewModels.HomeViewModel

<div class="dashboard">
    <div class="balance-card text-center p-4 mb-4" style="background: #FF85A1; color: white; border-radius: 20px;">
        <p class="mb-1">Загальний баланс</p>
        <h1 class="display-4 fw-bold">@Model.TotalBalance ₴</h1>
        
        <div class="d-flex justify-content-around mt-3">
            <div>
                <small>Доходи</small>
                <p class="mb-0 fw-bold">+@Model.TotalIncome ₴</p>
            </div>
            <div>
                <small>Витрати</small>
                <p class="mb-0 fw-bold">-@Model.TotalExpense ₴</p>
            </div>
        </div>
    </div>

    <div class="text-center mb-4">
        <a href="/Transaction/Create" class="btn btn-lg px-5" style="background: #FF85A1; color: white; border-radius: 50px;">+ Додати запис</a>
    </div>

    <div class="transactions-list">
        <h5 class="mb-3">Останні операції</h5>
        @if (Model.RecentTransactions.Any())
        {
            @foreach (var item in Model.RecentTransactions)
            {
                <div class="card mb-2 border-0 shadow-sm" style="border-radius: 15px;">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="mb-0 fw-bold">@item.CategoryName</p>
                            <small class="text-muted">@item.DateCreated.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                        <div class="fw-bold @(item.Type == "Income" ? "text-success" : "text-danger")">
                            @(item.Type == "Income" ? "+" : "-") @item.Amount ₴
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted text-center">Записів ще немає. Додайте перший!</p>
        }
    </div>
</div>