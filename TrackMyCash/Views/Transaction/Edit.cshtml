@model TrackMyCash.Models.ViewModels.TransactionViewModel
@{
    ViewData["Title"] = "Редагувати транзакцію - TrackMyCash";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-pink text-white">
                    <h5 class="mb-0">✏️ Редагувати транзакцію</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Тип транзакції</label>
                            <select asp-for="Type" class="form-select">
                                <option value="Income">✅ Дохід</option>
                                <option value="Expense">❌ Витрата</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Сума (грн)</label>
                            <input type="number" asp-for="Amount" class="form-control" step="0.01" required>
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label">Категорія</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required></select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DateCreated" class="form-label">Дата</label>
                            <input type="date" asp-for="DateCreated" class="form-control">
                            <span asp-validation-for="DateCreated" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Comment" class="form-label">Коментар (необов'язково)</label>
                            <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-pink flex-grow-1">💾 Оновити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
