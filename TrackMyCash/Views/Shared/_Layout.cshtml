<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrackMyCash</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-pink">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">💖 TrackMyCash</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Головна</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Transaction" asp-action="Index">Транзакції</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Category" asp-action="Index">Категорії</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Analytics" asp-action="Index">Аналітика</a></li>
                </ul>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-light">Вийти</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light me-2" asp-controller="Account" asp-action="Login">Увійти</a>
                    <a class="btn btn-light" asp-controller="Account" asp-action="Register">Реєстрація</a>
                }
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        @RenderBody()
    </main>

    <footer class="bg-light text-center py-3 mt-5">
        <p>© 2026 TrackMyCash — Навчальна практика</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>