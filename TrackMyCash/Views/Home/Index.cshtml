@model TrackMyCash.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Головна - TrackMyCash";
}

<div class="container mt-4">

    <!-- Баланс -->
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="text-pink">💰 Мій баланс</h1>
            <div class="balance-card mt-3 p-5">
                <h2 class="mb-0">@Model.Balance.ToString("C") грн</h2>
            </div>
        </div>
    </div>

    <!-- Швидке додавання -->
    <div class="card mt-5">
        <div class="card-header bg-pink text-white">
            <h5>Швидке додавання операції</h5>
        </div>
        <div class="card-body">
            <form asp-action="AddQuickTransaction" method="post">
                <div class="row g-3">
                    <div class="col-md-2">
                        <select asp-for="Type" class="form-select">
                            <option value="Income">Дохід</option>
                            <option value="Expense">Витрата</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <input type="number" asp-for="Amount" class="form-control" placeholder="Сума" step="0.01" required />
                    </div>
                    <div class="col-md-3">
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required></select>
                    </div>
                    <div class="col-md-3">
                        <input type="text" asp-for="Comment" class="form-control" placeholder="Коментар (необов'язково)" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-pink w-100">Додати</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Останні транзакції -->
    <h4 class="mt-5">Останні операції</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Тип</th>
                <th>Категорія</th>
                <th>Сума</th>
                <th>Коментар</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.RecentTransactions)
            {
                <tr>
                    <td>@t.DateCreated.ToShortDateString()</td>
                    <td>@(t.Type == "Income" ? "➕ Дохід" : "➖ Витрата")</td>
                    <td>@t.Category?.Name</td>
                    <td class="@(t.Type == "Income" ? "text-success" : "text-danger")">@t.Amount.ToString("C")</td>
                    <td>@t.Comment</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .balance-card {
        background: linear-gradient(135deg, #ff69b4, #ff1493);
        color: white;
        border-radius: 20px;
        max-width: 450px;
        margin: 0 auto;
    }
    .btn-pink {
        background-color: #ff69b4;
        color: white;
    }
    .btn-pink:hover {
        background-color: #ff1493;
    }
</style>