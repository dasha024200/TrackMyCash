@model TrackMyCash.Models.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація - TrackMyCash";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header bg-pink text-white">
                    <h4 class="mb-0 text-center">💖 Приєднайтеся до TrackMyCash</h4>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Register" method="post">
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Електронна пошта</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="your@email.com" required>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Пароль</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" required>
                            <small class="text-muted">Мінімум 6 символів</small>
                            <span asp-validation-for="Password" class="text-danger small d-block"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Підтворіти пароль</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" required>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                        <button type="submit" class="btn btn-pink w-100 mb-3">✨ Зареєструватися</button>
                    </form>

                    <div class="text-center">
                        <p>
                            Вже є акаунт?
                            <a asp-action="Login" class="action-link">Увійти</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}