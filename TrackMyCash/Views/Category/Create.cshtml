@model TrackMyCash.Models.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "Нова категорія - TrackMyCash";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-pink text-white">
                    <h5 class="mb-0">🏷️ Створити категорію</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Назва категорії</label>
                            <input type="text" asp-for="Name" class="form-control" placeholder="Наприклад: Продукти" required>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label">Тип</label>
                            <select asp-for="Type" class="form-select" required>
                                <option value="">-- Оберіть тип --</option>
                                <option value="Income">✅ Дохід</option>
                                <option value="Expense">❌ Витрата</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-pink flex-grow-1">💾 Зберегти</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
