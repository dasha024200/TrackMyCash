@model List<TrackMyCash.Models.Category>
@{
    ViewData["Title"] = "Керування категоріями - TrackMyCash";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="text-pink">🏷️ Мої категорії</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-pink">
                <i class="bi bi-plus-circle"></i> Нова категорія
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center p-4">
            <h5>Немає категорій</h5>
            <p>Створіть перші категорії для організації ваших транзакцій.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var category in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h5 class="card-title">
                                        @category.Name
                                        @if (category.IsDefault)
                                        {
                                            <span class="badge bg-info ms-2">Стандартна</span>
                                        }
                                    </h5>
                                    <p class="card-text">
                                        <strong>Тип:</strong>
                                        @if (category.Type == "Income")
                                        {
                                            <span class="badge bg-success">Дохід</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Витрата</span>
                                        }
                                    </p>
                                </div>
                                <div>
                                    @if (!category.IsDefault)
                                    {
                                        <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary" title="Редагувати">
                                            ✏️
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
